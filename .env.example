# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# CMS administrator
ADMIN_EMAIL=admin@example.com
# Paste the generated value exactly; bcrypt dollar signs must remain escaped.
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Cloudflare R2 S3 credentials (create an Object Read & Write R2 token)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dmg-blog-assets

# Optional. Use a production custom domain such as https://assets.example.com.
# Leave empty to keep the bucket private and serve images through the app.
R2_PUBLIC_URL=

# Cloudflare edge cache purge after published blog changes
# Create a zone-scoped token with Zone -> Cache Purge -> Purge permission.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
